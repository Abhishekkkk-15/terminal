{
  "$schema": "https://schemas.tauri.app/core/schema/config/v2",
  "productName": "Warp Terminal",
  "version": "0.1.0",
  "identifier": "dev.warp.terminal-ui",
  "build": {
    "beforeDevCommand": "pnpm run tauri:vite-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run tauri:vite-build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Warp Terminal",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "theme": "Dark",
        "center": true,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "AI-native terminal emulator",
    "longDescription": "A modern AI-native terminal frontend inspired by Warp, built with React and Tauri."
  }
}
